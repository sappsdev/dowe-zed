{
  "grammars": [
    {
      "name": "dowe",
      "camelcase": "Dowe",
      "scope": "source.dowe",
      "path": ".",
      "file-types": ["dowe"]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Dowe Source Format grammar for tree-sitter",
    "authors": [
      {
        "name": "Dowe Contributors"
      }
    ],
    "links": {
      "repository": "https://github.com/dowe-lang/dowe-zed"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
